<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="100%" height="100%">
    <defs>
        <!-- Metallic Gold/Bronze Gradient -->
        <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#f6e0a4" />
            <stop offset="30%" stop-color="#dfb76c" />
            <stop offset="50%" stop-color="#c5a368" />
            <stop offset="70%" stop-color="#aa7c3c" />
            <stop offset="100%" stop-color="#8a5a22" />
        </linearGradient>
        <linearGradient id="gold-light" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#fff1d0" />
            <stop offset="50%" stop-color="#e3be7f" />
            <stop offset="100%" stop-color="#aa7c3c" />
        </linearGradient>

        <!-- Deep Royal Blue Banner Gradient -->
        <linearGradient id="banner-blue" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#07162c" />
            <stop offset="30%" stop-color="#123056" />
            <stop offset="50%" stop-color="#1e467a" />
            <stop offset="70%" stop-color="#123056" />
            <stop offset="100%" stop-color="#07162c" />
        </linearGradient>

        <!-- Natural Green Gradients for Symmetrical Foliage -->
        <radialGradient id="foliage-grad-1" cx="40%" cy="40%" r="60%">
            <stop offset="0%" stop-color="#3d8b55" />
            <stop offset="70%" stop-color="#1e4d2b" />
            <stop offset="100%" stop-color="#0f2916" />
        </radialGradient>
        <radialGradient id="foliage-grad-2" cx="30%" cy="30%" r="70%">
            <stop offset="0%" stop-color="#55b070" />
            <stop offset="60%" stop-color="#2e6f40" />
            <stop offset="100%" stop-color="#153b20" />
        </radialGradient>

        <!-- Textured Wood Trunk Gradient -->
        <linearGradient id="trunk-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#3d2314" />
            <stop offset="50%" stop-color="#694025" />
            <stop offset="100%" stop-color="#22130a" />
        </linearGradient>

        <!-- Bow Metallic Blue Gradient -->
        <linearGradient id="bow-blue" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#3b82f6" />
            <stop offset="50%" stop-color="#1e40af" />
            <stop offset="100%" stop-color="#1e3a8a" />
        </linearGradient>

        <!-- Majestic Elephant Skin & Ivory Tusks -->
        <linearGradient id="elephant-skin" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#f8fafc" />
            <stop offset="50%" stop-color="#cbd5e1" />
            <stop offset="100%" stop-color="#94a3b8" />
        </linearGradient>
        <linearGradient id="tusk-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#ffffff" />
            <stop offset="80%" stop-color="#f3eed9" />
            <stop offset="100%" stop-color="#d4caa4" />
        </linearGradient>

        <!-- Left-side Group containing Tree, Bow, Arrow, Ear, Eye, Tusk to ensure 100% Symmetrical Rendering -->
        <g id="left-half">
            <!-- Tree Trunk & Roots -->
            <path d="M 60 400 C 70 380, 80 340, 75 300 C 70 260, 95 240, 105 210 C 110 220, 115 240, 110 260 C 105 280, 105 320, 90 360 C 85 380, 95 390, 100 400 Z" fill="url(#trunk-grad)" stroke="#22130a" stroke-width="1" />
            <path d="M 75 385 C 65 390, 50 395, 42 410 C 48 410, 60 400, 70 395" fill="none" stroke="#22130a" stroke-width="2" />
            <path d="M 85 390 C 95 395, 110 400, 115 412 C 110 412, 100 405, 88 398" fill="none" stroke="#22130a" stroke-width="2" />
            
            <!-- Foliage (Overlapping green clusters) -->
            <circle cx="85" cy="180" r="28" fill="url(#foliage-grad-1)" />
            <circle cx="125" cy="170" r="32" fill="url(#foliage-grad-2)" />
            <circle cx="105" cy="150" r="35" fill="url(#foliage-grad-1)" />
            <circle cx="70" cy="155" r="26" fill="url(#foliage-grad-2)" />
            <circle cx="130" cy="195" r="24" fill="url(#foliage-grad-1)" />
            <circle cx="100" cy="190" r="28" fill="url(#foliage-grad-2)" opacity="0.95" />
            
            <!-- Blue Bow -->
            <path d="M 120 130 C 45 155, 45 245, 120 270" fill="none" stroke="url(#bow-blue)" stroke-width="5" stroke-linecap="round" />
            <!-- Gold Bow Tips -->
            <circle cx="120" cy="130" r="4.5" fill="url(#gold)" />
            <circle cx="120" cy="270" r="4.5" fill="url(#gold)" />
            <!-- Bow grip wrapper -->
            <rect x="73" y="192" width="6" height="16" rx="2" fill="url(#gold)" transform="rotate(-5, 76, 200)" />
            <!-- Bowstring -->
            <line x1="120" y1="130" x2="120" y2="270" stroke="#f1f5f9" stroke-width="1" stroke-dasharray="2,2" opacity="0.8" />
            <!-- Loaded Arrow pointing outwards -->
            <line x1="130" y1="200" x2="25" y2="200" stroke="#e2e8f0" stroke-width="2.5" stroke-linecap="round" />
            <polygon points="25,200 37,194 37,206" fill="url(#gold)" />
            <path d="M 128 200 L 138 191 L 134 200 L 138 209 Z" fill="url(#gold)" />
            <path d="M 118 200 L 126 193 L 123 200 L 126 207 Z" fill="url(#gold)" />

            <!-- Elephant Ear -->
            <path d="M 245 200 C 190 140, 110 180, 140 280 C 160 330, 210 320, 240 250 Z" fill="url(#elephant-skin)" stroke="#94a3b8" stroke-width="0.75" />
            <path d="M 235 210 C 195 165, 135 195, 155 270 C 170 305, 210 300, 230 250 Z" fill="#f8fafc" opacity="0.5" />

            <!-- Elephant Eye -->
            <ellipse cx="225" cy="215" rx="5" ry="3.5" fill="#1e293b" />
            <path d="M 215 208 C 220 205, 230 205, 235 208" stroke="#64748b" stroke-width="1" fill="none" />
            <circle cx="224" cy="214" r="1.5" fill="#ffffff" />

            <!-- Elephant Tusk -->
            <path d="M 225 265 C 195 285, 185 360, 165 390 C 185 350, 215 295, 235 270 Z" fill="url(#tusk-grad)" stroke="#94a3b8" stroke-width="0.5" />
        </g>
    </defs>

    <!-- Background Fill for Emblem inside Circular Border -->
    <circle cx="250" cy="250" r="226" fill="#0b1f3a" />

    <!-- Outer Circular Metallic Gold Borders -->
    <circle cx="250" cy="250" r="236" fill="none" stroke="url(#gold)" stroke-width="4" />
    <circle cx="250" cy="250" r="226" fill="none" stroke="url(#gold)" stroke-width="8" />
    <circle cx="250" cy="250" r="216" fill="none" stroke="url(#gold)" stroke-width="1.5" stroke-dasharray="3,3" opacity="0.8" />
    <circle cx="250" cy="250" r="212" fill="none" stroke="url(#gold)" stroke-width="0.75" opacity="0.5" />

    <!-- Ornate Diamond details at cardinal points -->
    <polygon points="250,8 253,13 250,18 247,13" fill="url(#gold)" />
    <polygon points="250,492 253,487 250,482 247,487" fill="url(#gold)" />
    <polygon points="8,250 13,253 18,250 13,247" fill="url(#gold)" />
    <polygon points="492,250 487,253 482,250 487,247" fill="url(#gold)" />

    <!-- Render Left Half -->
    <use href="#left-half" />

    <!-- Render Right Half (Symmetrical Mirror) -->
    <use href="#left-half" transform="translate(500, 0) scale(-1, 1)" />

    <!-- Centered Elephant Forehead & Wrinkles -->
    <path d="M 210 180 C 210 130, 290 130, 290 180 C 290 220, 210 220, 210 180 Z" fill="url(#elephant-skin)" stroke="#94a3b8" stroke-width="1.2" />
    <path d="M 230 155 C 240 150, 260 150, 270 155" fill="none" stroke="#64748b" stroke-width="1" />
    <path d="M 225 168 C 235 162, 265 162, 275 168" fill="none" stroke="#64748b" stroke-width="1" />
    <path d="M 220 180 C 235 174, 265 174, 280 180" fill="none" stroke="#64748b" stroke-width="1.2" />

    <!-- Centered Elephant Trunk with Horizontal Creases -->
    <path d="M 235 245 C 235 320, 240 420, 244 445 C 247 448, 253 448, 256 445 C 260 420, 265 320, 265 245 Z" fill="url(#elephant-skin)" stroke="#94a3b8" stroke-width="1.2" />
    <line x1="237" y1="265" x2="263" y2="265" stroke="#64748b" stroke-width="1" />
    <line x1="238" y1="285" x2="262" y2="285" stroke="#64748b" stroke-width="1" />
    <line x1="240" y1="305" x2="260" y2="305" stroke="#64748b" stroke-width="1" />
    <line x1="241" y1="325" x2="259" y2="325" stroke="#64748b" stroke-width="1" />
    <line x1="242" y1="345" x2="258" y2="345" stroke="#64748b" stroke-width="1" />
    <line x1="243" y1="365" x2="257" y2="365" stroke="#64748b" stroke-width="1" />
    <line x1="244" y1="385" x2="256" y2="385" stroke="#64748b" stroke-width="1" />
    <line x1="245" y1="405" x2="255" y2="405" stroke="#64748b" stroke-width="1" />
    <line x1="245" y1="425" x2="255" y2="425" stroke="#64748b" stroke-width="1" />

    <!-- Top Ribbon/Banner ("OLOROKE BIRIGUI") -->
    <path d="M 100 150 A 180 180 0 0 1 400 150" fill="none" stroke="url(#gold)" stroke-width="32" stroke-linecap="round" />
    <path d="M 100 150 A 180 180 0 0 1 400 150" fill="none" stroke="url(#banner-blue)" stroke-width="26" stroke-linecap="round" />
    <path id="top-text-path-hd" d="M 100 151 A 180 180 0 0 1 400 151" fill="none" />
    <text font-family="'Playfair Display', 'Georgia', serif" font-weight="bold" font-size="19" fill="url(#gold-light)" letter-spacing="1.5" text-anchor="middle">
        <textPath href="#top-text-path-hd" startOffset="50%">OLOROKE BIRIGUI</textPath>
    </text>

    <!-- Bottom Ribbon/Banner ("TERREIRO DE AXÉ") -->
    <path d="M 100 350 A 180 180 0 0 0 400 350" fill="none" stroke="url(#gold)" stroke-width="32" stroke-linecap="round" />
    <path d="M 100 350 A 180 180 0 0 0 400 350" fill="none" stroke="url(#banner-blue)" stroke-width="26" stroke-linecap="round" />
    <path id="bottom-text-path-hd" d="M 100 348 A 180 180 0 0 0 400 348" fill="none" />
    <text font-family="'Playfair Display', 'Georgia', serif" font-weight="bold" font-size="18" fill="url(#gold-light)" letter-spacing="1.5" text-anchor="middle">
        <textPath href="#bottom-text-path-hd" startOffset="50%">TERREIRO DE AXÉ</textPath>
    </text>

    <!-- Subtitle "DESDE 2024" -->
    <text x="250" y="415" font-family="'Playfair Display', 'Georgia', serif" font-weight="bold" font-size="12" fill="url(#gold)" text-anchor="middle" letter-spacing="2">DESDE 2024</text>
</svg>
